JF_FILE_PATH=.github/linters/super-linter.env
JF_FILE_VERSION=1.1.1
JF_FILE_GUID=a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d

VALIDATE_ALL_CODEBASE=false
DEFAULT_BRANCH=main
DISABLE_ERRORS=false
LOG_LEVEL=INFO
VALIDATE_JSCPD=false
FIX_ANSIBLE=false
FIX_CLANG_FORMAT=false
FIX_CSHARP=false
FIX_CSS=false
FIX_CSS_PRETTIER=true
FIX_DOTNET_SLN_FORMAT_ANALYZERS=false
FIX_DOTNET_SLN_FORMAT_STYLE=false
FIX_DOTNET_SLN_FORMAT_WHITESPACE=false
FIX_ENV=true
FIX_GITHUB_ACTIONS_ZIZMOR=true
FIX_GO=true
FIX_GO_MODULES=true
FIX_GOOGLE_JAVA_FORMAT=true
FIX_GRAPHQL_PRETTIER=true
FIX_GROOVY=true
FIX_HTML_PRETTIER=true
FIX_JAVASCRIPT_ES=true
FIX_JAVASCRIPT_PRETTIER=true
FIX_JSON=false
FIX_JSON_PRETTIER=true
FIX_JSONC=false
FIX_JSONC_PRETTIER=true
FIX_JSX=false
FIX_JSX_PRETTIER=true
FIX_JUPYTER_NBQA_BLACK=false
FIX_JUPYTER_NBQA_ISORT=false
FIX_JUPYTER_NBQA_RUFF=false
FIX_KOTLIN=true
FIX_MARKDOWN=false
FIX_MARKDOWN_PRETTIER=true
FIX_NATURAL_LANGUAGE=true
FIX_POWERSHELL=true
FIX_PROTOBUF=true
FIX_PYTHON_BLACK=false
FIX_PYTHON_ISORT=false
FIX_PYTHON_RUFF=true
FIX_RUBY=true
FIX_RUST_2015=true
FIX_RUST_2018=true
FIX_RUST_2021=true
FIX_RUST_CLIPPY=false
FIX_SCALAFMT=false
FIX_SHELL_SHFMT=true
FIX_SNAKEMAKE_SNAKEFMT=false
FIX_SQLFLUFF=false
FIX_TERRAFORM_FMT=false
FIX_TSX=true
FIX_TYPESCRIPT_ES=true
FIX_TYPESCRIPT_PRETTIER=true
FIX_VUE=false
FIX_VUE_PRETTIER=false
FIX_YAML_PRETTIER=true
FILTER_REGEX_EXCLUDE=\.github/linters/super-linter\.env$
IGNORE_GENERATED_FILES=true
IGNORE_GITIGNORED_FILES=false
ENABLE_GITHUB_ACTIONS_GROUP_TITLE=true
ENABLE_GITHUB_ACTIONS_STEP_SUMMARY=true
SAVE_SUPER_LINTER_OUTPUT=false
SAVE_SUPER_LINTER_SUMMARY=false
CREATE_LOG_FILE=false
MULTI_STATUS=true
REMOVE_ANSI_COLOR_CODES_FROM_OUTPUT=false
SUPPRESS_FILE_TYPE_WARN=false
SUPPRESS_POSSUM=false
BASH_EXEC_IGNORE_LIBRARIES=false
GROOVY_FAILON_LEVEL=warning
GROOVY_LOG_LEVEL=info
YAML_ERROR_ON_WARNING=false
LINTER_RULES_PATH=.github/linters
SSH_SETUP_GITHUB=false
SSH_INSECURE_NO_VERIFY_GITHUB_KEY=false
USE_FIND_ALGORITHM=false
RUN_LOCAL=false
FAIL_ON_CONFLICTING_TOOLS_ENABLED=false
ENABLE_COMMITLINT_EDIT_MODE=false
ENABLE_COMMITLINT_STRICT_MODE=false
ENFORCE_COMMITLINT_CONFIGURATION_CHECK=false
SUPER_LINTER_OUTPUT_DIRECTORY_NAME=super-linter-output
SUPER_LINTER_SUMMARY_FILE_NAME=super-linter-summary.md
OS_PACKAGES_CONFIG_FILE_NAME=os-packages.json
